{
  "name": "code-challenge-tl",
  "version": "1.0.0",
  "private": true,
  "description": "Challenge 1 - Payment settlement pipeline",
  "scripts": {
    "start:payment-api": "tsx apps/payment-api/src/main.ts",
    "start:outbox-relay": "tsx apps/outbox-relay/src/main.ts",
    "start:fraud-worker": "tsx apps/fraud-worker/src/main.ts",
    "start:ledger-worker": "tsx apps/ledger-worker/src/main.ts",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
